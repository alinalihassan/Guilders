# Postgres database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/guilders

# Dashboard, used for redirecting to the dashboard
BACKEND_URL=http://localhost:3000
DASHBOARD_URL=http://localhost:3002

# Secret used for provider state verification
GUILDERS_SECRET=
# Set to 0 to disable the transaction enrichment queue (e.g. to test raw data with scripts).
# TRANSACTION_ENRICHMENT_ENABLED=0

# Better Auth, used for authentication
BETTER_AUTH_SECRET=

# Stripe
STRIPE_PRO_PRICE_ID=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Resend, used for sending emails
RESEND_API_KEY=

# Cloudflare
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_AI_GATEWAY=
CLOUDFLARE_AI_GATEWAY_TOKEN=
CLOUDFLARE_R2_ACCESS_KEY=
CLOUDFLARE_R2_SECRET_KEY=

# Dev tunnel URL: used in development for provider webhook/callback URLs (Teller, EnableBanking, GoCardless).
# For a stable URL so you don't re-register each provider when the tunnel restarts, use a persistent
# Cloudflare Tunnel or Ngrok URL — see apps/api/TUNNEL.md.
# Optional; omit if you have a public API URL.
NGROK_URL=

# Providers, optional, used for open banking providers
## Snaptrade
SNAPTRADE_CLIENT_ID=
SNAPTRADE_CLIENT_SECRET=

## SaltEdge
SALTEDGE_APP_ID=
SALTEDGE_SECRET=

## GoCardless (Bank Account Data / Nordigen)
GOCARDLESS_SECRET_ID=
GOCARDLESS_SECRET_KEY=
