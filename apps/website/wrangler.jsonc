{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "guilders-website",
  "compatibility_date": "2026-02-27",
  "assets": {
    "directory": "./dist",
    "not_found_handling": "404-page",
  },
  "routes": [
    {
      "custom_domain": true,
      "pattern": "guilders.app",
    },
  ],
  "workers_dev": false,
  "preview_urls": false,
  "observability": {
    "enabled": true,
    "traces": {
      "enabled": true,
    },
  },
}
