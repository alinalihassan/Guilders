---
import { DOCS_URL, DASHBOARD_URL, GITHUB_URL } from "../config";

const links = [
  { label: "DOCS", href: DOCS_URL },
  { label: "DASHBOARD", href: DASHBOARD_URL },
  { label: "GITHUB", href: GITHUB_URL },
];
---
<header class="border-b-3 border-line sticky top-0 z-50 bg-bg/95 backdrop-blur-sm">
  <div class="flex items-center justify-between px-5 py-4 md:px-8">
    <a href="/" class="flex items-center gap-3 hover:no-underline group">
      <img src="/assets/logo/logo.svg" alt="" width="24" height="24" />
      <span class="font-display text-base font-bold uppercase tracking-wider text-fg group-hover:text-gold transition-colors duration-100">
        Guilders
      </span>
    </a>
    <nav class="flex items-center gap-6 md:gap-8">
      {links.map((link) => (
        <a
          href={link.href}
          {...(link.href !== DASHBOARD_URL ? { target: "_blank", rel: "noopener noreferrer" } : {})}
          class="text-[11px] font-mono font-medium uppercase tracking-[0.2em] text-dim hover:text-gold transition-colors duration-100"
        >
          {link.label}
        </a>
      ))}
    </nav>
  </div>
</header>
