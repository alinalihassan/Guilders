---
import { GITHUB_URL } from "../config";
---
<section class="border-b-3 border-line px-5 py-20 md:px-8 md:py-28">
  <p class="text-[11px] font-bold uppercase tracking-[0.2em] text-dim mb-8">
    Open source
  </p>
  <h2 class="font-display text-big font-black uppercase leading-[0.95] tracking-tight text-fg">
    Open source.<br/>
    Self-hostable.<br/>
    <span class="text-gold">Yours.</span>
  </h2>
  <p class="mt-10 max-w-lg text-dim leading-relaxed">
    No vendor lock-in. Run the full stack on your own infrastructure.
    Privacy-first, built for Europe and everywhere else where personal
    finance tools are limited.
  </p>

  <div class="mt-10 flex items-center gap-6">
    <a
      href={GITHUB_URL}
      target="_blank"
      rel="noopener noreferrer"
      class="inline-block border-3 border-gold px-8 py-3 text-[11px] font-bold uppercase tracking-[0.25em] text-gold hover:bg-gold hover:text-bg transition-colors duration-100 hover:no-underline"
    >
      View source →
    </a>
    <a
      href={GITHUB_URL}
      target="_blank"
      rel="noopener noreferrer"
      class="text-[11px] font-medium uppercase tracking-[0.2em] text-dim hover:text-gold transition-colors duration-100"
    >
      ★ Star on GitHub
    </a>
  </div>
</section>
