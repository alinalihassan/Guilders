---
const features = [
  { id: "01", name: "NET WORTH", desc: "Assets and liabilities. Banks, brokerages, crypto, property, loans." },
  { id: "02", name: "BANK SYNC", desc: "Open banking via SaltEdge. Brokerage sync via SnapTrade." },
  { id: "03", name: "MANUAL ACCOUNTS", desc: "Cash, collectibles, real estate — anything without an API." },
  { id: "04", name: "CATEGORIES", desc: "Hierarchical, customizable. Expense and income classification." },
  { id: "05", name: "MULTI-CURRENCY", desc: "Any ISO currency. Automatic exchange rate updates." },
  { id: "06", name: "AI ADVISOR", desc: "Chat with an LLM that sees your full financial picture." },
];
---
<section class="border-b-3 border-line">
  <div class="border-b border-line px-5 py-4 md:px-8">
    <span class="text-[11px] font-bold uppercase tracking-[0.2em] text-dim">
      Features
    </span>
  </div>
  <div class="divide-y divide-line">
    {features.map((f) => (
      <div class="group flex items-baseline gap-6 px-5 py-5 md:px-8 md:gap-10 hover:bg-line/30 transition-colors duration-75">
        <span class="shrink-0 font-mono text-[11px] font-medium text-dim tabular-nums">
          {f.id}
        </span>
        <div class="flex flex-col gap-1 md:flex-row md:items-baseline md:gap-8 flex-1">
          <h3 class="shrink-0 font-display text-base font-bold uppercase tracking-wide text-fg md:w-56">
            {f.name}
          </h3>
          <p class="text-dim text-sm leading-relaxed">
            {f.desc}
          </p>
        </div>
      </div>
    ))}
  </div>
</section>
