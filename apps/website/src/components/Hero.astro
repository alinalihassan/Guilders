---
import { DASHBOARD_URL } from "../config";
---
<section class="border-b-3 border-line px-5 pt-20 pb-20 md:px-8 md:pt-28 md:pb-28">
  <h1 class="font-display text-massive font-black uppercase leading-[0.9] tracking-tight text-fg">
    Your<br/>
    <span class="text-gold">money</span><br/>
    tracked
  </h1>
  <div class="mt-14 flex flex-col gap-8 md:flex-row md:items-end md:justify-between">
    <div class="max-w-md">
      <p class="text-dim leading-relaxed">
        Open-source personal finance platform. Bank accounts, investments, crypto, property — one dashboard. Self-host the entire stack or use ours. We don't mind.
      </p>
      <p class="mt-3 text-dim leading-relaxed">
        No tracking. No lock-in. No bullshit.
      </p>
    </div>
    <a
      href={DASHBOARD_URL}
      class="inline-block border-3 border-gold bg-transparent px-8 py-3 text-[11px] font-bold uppercase tracking-[0.25em] text-gold hover:bg-gold hover:text-bg transition-colors duration-100 hover:no-underline shrink-0"
    >
      Open dashboard →
    </a>
  </div>
</section>
